# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Model used for answer generation (must be a Groq-hosted model)
GROQ_MODEL=llama-3.3-70b-versatile

# Local sentence-transformers model used for embeddings (downloaded on first run)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# SQLite file path (relative to backend/)
DATABASE_PATH=data/inbox.db

# Chunking
CHUNK_SIZE_CHARS=800
CHUNK_OVERLAP_CHARS=120

# Retrieval
TOP_K_DEFAULT=4

CORS_ORIGINS=http://localhost:5173
